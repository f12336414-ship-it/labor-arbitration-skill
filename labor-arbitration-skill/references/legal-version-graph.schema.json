{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/f12336414-ship-it/labor-arbitration-skill/legal-version-graph.schema.json",
  "title": "Unverified legal-source version candidate graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "graph_id",
    "document_id",
    "publisher_code",
    "jurisdiction",
    "generated_at",
    "snapshot_canonicalization",
    "versions",
    "relationships",
    "limitations",
    "graph_snapshot_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "graph_id": {"type": "string", "pattern": "^LEGAL-GRAPH-[A-Z0-9][A-Z0-9_-]{0,47}$"},
    "document_id": {"$ref": "#/$defs/identifier"},
    "publisher_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
    "jurisdiction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["country", "province"],
      "properties": {
        "country": {"const": "CN"},
        "province": {"const": "Beijing"}
      }
    },
    "generated_at": {"type": "string", "format": "date-time"},
    "snapshot_canonicalization": {"const": "RFC8785"},
    "versions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {"$ref": "#/$defs/version"}
    },
    "relationships": {
      "type": "array",
      "maxItems": 1000,
      "items": {"$ref": "#/$defs/relationship"}
    },
    "limitations": {
      "const": [
        "VERSION_RELATIONSHIPS_UNVERIFIED_CANDIDATES",
        "FROZEN_RECORD_EXISTENCE_NOT_VERIFIED_BY_GRAPH_ONLY",
        "LEGAL_CURRENTNESS_AND_APPLICABILITY_NOT_VERIFIED"
      ]
    },
    "graph_snapshot_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64,
      "pattern": "^[A-Z][A-Z0-9_-]+$"
    },
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nullable_date": {
      "oneOf": [{"type": "string", "format": "date"}, {"type": "null"}]
    },
    "version": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version_id",
        "source_url",
        "frozen_record_snapshot_sha256",
        "content_sha256",
        "publication_date_candidate",
        "effective_from_candidate",
        "effective_to_candidate",
        "status",
        "legal_review_status"
      ],
      "properties": {
        "version_id": {"$ref": "#/$defs/identifier"},
        "source_url": {"type": "string", "pattern": "^https://", "maxLength": 2048},
        "frozen_record_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "content_sha256": {"$ref": "#/$defs/sha256"},
        "publication_date_candidate": {"$ref": "#/$defs/nullable_date"},
        "effective_from_candidate": {"$ref": "#/$defs/nullable_date"},
        "effective_to_candidate": {"$ref": "#/$defs/nullable_date"},
        "status": {"const": "UNVERIFIED_VERSION_CANDIDATE"},
        "legal_review_status": {"const": "PENDING_INDEPENDENT_LEGAL_REVIEW"}
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relationship_id",
        "from_version_id",
        "to_version_id",
        "relationship_type",
        "basis_frozen_record_snapshot_sha256",
        "text_diff_snapshot_sha256",
        "status"
      ],
      "properties": {
        "relationship_id": {"$ref": "#/$defs/identifier"},
        "from_version_id": {"$ref": "#/$defs/identifier"},
        "to_version_id": {"$ref": "#/$defs/identifier"},
        "relationship_type": {
          "enum": ["AMENDS", "REPEALS", "SUPERSEDES", "CORRECTS", "CONFLICTS_WITH"]
        },
        "basis_frozen_record_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "text_diff_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "status": {"const": "UNVERIFIED_RELATIONSHIP_CANDIDATE"}
      }
    }
  }
}
