{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/f12336414-ship-it/labor-arbitration-skill/fact-analysis-input.schema.json",
  "title": "Local structured fact analysis input",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_id", "created_at", "inputs", "previous_analysis_record"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_id": {"type": "string", "pattern": "^ANALYSIS-[A-Z0-9][A-Z0-9_-]{0,55}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "inputs": {
      "type": "array", "minItems": 1, "maxItems": 1000,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["view_key", "dimension_key", "semantic_kind", "value", "timeline_role", "actor_label", "fact_candidate_record", "parse_record", "previous_fact_candidate_record"],
        "properties": {
          "view_key": {"$ref": "#/$defs/key"},
          "dimension_key": {"$ref": "#/$defs/key"},
          "semantic_kind": {"enum": ["DATE", "AMOUNT_CNY", "SUBJECT_KEY"]},
          "value": {"type": "string", "minLength": 1, "maxLength": 256},
          "timeline_role": {"enum": ["NONE", "EMPLOYMENT_START", "EMPLOYMENT_END", "TERMINATION"]},
          "actor_label": {"type": "string", "minLength": 1, "maxLength": 128},
          "fact_candidate_record": {"type": "object"},
          "parse_record": {"type": "object"},
          "previous_fact_candidate_record": {"type": ["object", "null"]}
        }
      }
    },
    "previous_analysis_record": {"type": ["object", "null"]}
  },
  "$defs": {
    "key": {"type": "string", "minLength": 3, "maxLength": 128, "pattern": "^[A-Z][A-Z0-9_.:-]+$"}
  }
}
