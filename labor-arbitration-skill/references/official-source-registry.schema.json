{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/f12336414-ship-it/labor-arbitration-skill/official-source-registry.schema.json",
  "title": "Reviewed official-source candidate registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "reviewed_at", "entries"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "reviewed_at": {"type": "string", "format": "date"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {"$ref": "#/$defs/entry"}
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publisher_code",
        "authority_name",
        "hosts",
        "permitted_purposes",
        "allowed_media_types",
        "max_response_bytes",
        "minimum_interval_seconds",
        "single_request_only",
        "automated_access_authorization_status",
        "evidence_urls"
      ],
      "properties": {
        "publisher_code": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]+$"
        },
        "authority_name": {"type": "string", "minLength": 1, "maxLength": 200},
        "hosts": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9.-]+$",
            "maxLength": 253
          }
        },
        "permitted_purposes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["NORMATIVE_LEGAL_SOURCE", "OFFICIAL_CASE"]
          }
        },
        "allowed_media_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "text/html",
              "text/plain",
              "application/pdf",
              "application/json",
              "application/xml",
              "text/xml"
            ]
          }
        },
        "max_response_bytes": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 26214400
        },
        "minimum_interval_seconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3600
        },
        "single_request_only": {"const": true},
        "automated_access_authorization_status": {"const": "NOT_ASSERTED"},
        "evidence_urls": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^https://", "maxLength": 2048}
        }
      }
    }
  }
}
