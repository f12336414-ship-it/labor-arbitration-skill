{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/f12336414-ship-it/labor-arbitration-skill/fact-analysis-record.schema.json",
  "title": "Deterministic structured fact conflict and invalidation record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "analysis_id", "artifact_id", "created_at", "clock_status",
    "engine", "views", "conflicts", "upstream_snapshot_sha256", "previous_binding",
    "invalidation", "output_permission", "limitations", "record_snapshot_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "analysis_id": {"type": "string", "pattern": "^FANALYSIS-[0-9A-F]{24}$"},
    "artifact_id": {"type": "string", "pattern": "^ANALYSIS-[A-Z0-9][A-Z0-9_-]{0,55}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "clock_status": {"const": "SYSTEM_CLOCK_UNATTESTED"},
    "engine": {
      "const": {
        "name": "STRUCTURED_FACT_CONFLICTS",
        "version": "1.0.0",
        "comparison_policy": "EXACT_CANONICAL_STRING_ALL_UNEQUAL_PAIRS"
      }
    },
    "views": {
      "type": "array", "minItems": 1, "maxItems": 1000,
      "items": {"$ref": "#/$defs/view"}
    },
    "conflicts": {
      "type": "array", "maxItems": 10000,
      "items": {"$ref": "#/$defs/conflict"}
    },
    "upstream_snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "previous_binding": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object", "additionalProperties": false,
          "required": ["analysis_id", "artifact_id", "upstream_snapshot_sha256", "record_snapshot_sha256"],
          "properties": {
            "analysis_id": {"type": "string", "pattern": "^FANALYSIS-[0-9A-F]{24}$"},
            "artifact_id": {"type": "string", "pattern": "^ANALYSIS-[A-Z0-9][A-Z0-9_-]{0,55}$"},
            "upstream_snapshot_sha256": {"$ref": "#/$defs/sha256"},
            "record_snapshot_sha256": {"$ref": "#/$defs/sha256"}
          }
        }
      ]
    },
    "invalidation": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "changed_view_keys", "reason"],
      "properties": {
        "status": {"enum": ["BASELINE_CURRENT", "CURRENT", "INVALIDATED_BY_FACT_CHANGE"]},
        "changed_view_keys": {"type": "array", "maxItems": 1000, "uniqueItems": true, "items": {"$ref": "#/$defs/key"}},
        "reason": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    },
    "output_permission": {"const": "INTERNAL_ANALYSIS_ONLY"},
    "limitations": {
      "const": [
        "STRUCTURED_VALUES_ARE_USER_SUPPLIED_UNAUTHENTICATED",
        "CONFLICT_DETECTION_DOES_NOT_RESOLVE_FACT_TRUTH",
        "NO_EVIDENCE_OR_IDENTITY_AUTHENTICATION",
        "DOWNSTREAM_REVALIDATION_COVERS_THIS_LEDGER_ONLY",
        "NO_LEGAL_OR_SUBMISSION_READINESS"
      ]
    },
    "record_snapshot_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "key": {"type": "string", "minLength": 3, "maxLength": 128, "pattern": "^[A-Z][A-Z0-9_.:-]+$"},
    "view": {
      "type": "object", "additionalProperties": false,
      "required": [
        "view_id", "view_key", "dimension_key", "semantic_kind", "value",
        "timeline_role", "actor_assertion", "actor_label", "fact_candidate_binding",
        "value_status", "truth_status", "view_snapshot_sha256"
      ],
      "properties": {
        "view_id": {"type": "string", "pattern": "^VIEW-[0-9A-F]{24}$"},
        "view_key": {"$ref": "#/$defs/key"},
        "dimension_key": {"$ref": "#/$defs/key"},
        "semantic_kind": {"enum": ["DATE", "AMOUNT_CNY", "SUBJECT_KEY"]},
        "value": {"type": "string", "minLength": 1, "maxLength": 256},
        "timeline_role": {"enum": ["NONE", "EMPLOYMENT_START", "EMPLOYMENT_END", "TERMINATION"]},
        "actor_assertion": {"const": "USER_STRUCTURED_UNAUTHENTICATED"},
        "actor_label": {"type": "string", "minLength": 1, "maxLength": 128},
        "fact_candidate_binding": {
          "type": "object", "additionalProperties": false,
          "required": ["fact_candidate_id", "record_snapshot_sha256", "parse_id", "parse_record_snapshot_sha256", "provenance_state"],
          "properties": {
            "fact_candidate_id": {"type": "string", "pattern": "^FACT-[0-9A-F]{24}$"},
            "record_snapshot_sha256": {"$ref": "#/$defs/sha256"},
            "parse_id": {"type": "string", "pattern": "^PARSE-[0-9A-F]{24}$"},
            "parse_record_snapshot_sha256": {"$ref": "#/$defs/sha256"},
            "provenance_state": {"enum": ["EXTRACTED", "USER_ANNOTATED", "ADJUDICATED"]}
          }
        },
        "value_status": {"const": "USER_STRUCTURED_UNAUTHENTICATED"},
        "truth_status": {"const": "UNVERIFIED"},
        "view_snapshot_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "conflict": {
      "type": "object", "additionalProperties": false,
      "required": ["conflict_id", "conflict_type", "dimension_key", "view_ids", "values", "status", "auto_selected_view_id", "resolution"],
      "properties": {
        "conflict_id": {"type": "string", "pattern": "^CONFLICT-[0-9A-F]{24}$"},
        "conflict_type": {"enum": ["SEMANTIC_KIND_CONFLICT", "DATE_VALUE_CONFLICT", "AMOUNT_VALUE_CONFLICT", "SUBJECT_VALUE_CONFLICT", "TIMELINE_ORDER_CONFLICT", "TERMINATION_OUTSIDE_EMPLOYMENT_CONFLICT"]},
        "dimension_key": {"$ref": "#/$defs/key"},
        "view_ids": {"type": "array", "minItems": 2, "maxItems": 3, "uniqueItems": true, "items": {"type": "string", "pattern": "^VIEW-[0-9A-F]{24}$"}},
        "values": {"type": "array", "minItems": 2, "maxItems": 3, "items": {"type": "string", "minLength": 1, "maxLength": 256}},
        "status": {"const": "PENDING_HUMAN_REVIEW"},
        "auto_selected_view_id": {"type": "null"},
        "resolution": {"type": "null"}
      }
    }
  }
}
