{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/f12336414-ship-it/labor-arbitration-skill/blob/main/labor-arbitration-skill/references/intake-manifest.schema.json",
  "title": "Labor arbitration intake manifest",
  "description": "Schema 1.3 records bounded local byte observations and explicit unattested provenance. It does not authenticate the generator, files, timestamps, or user claims.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "integrity_semantics",
    "canonicalization",
    "generator",
    "provenance_boundary",
    "scan_observation",
    "output_security",
    "scan_policy",
    "summary",
    "relationships",
    "files",
    "manifest_payload_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.3"},
    "integrity_semantics": {"type": "string", "minLength": 1},
    "canonicalization": {"const": "RFC8785"},
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "build_identity_status",
        "runtime_source_sha256",
        "dependency_contract_sha256",
        "dependency_contract_kind",
        "python_version",
        "platform"
      ],
      "properties": {
        "name": {"const": "labor-arbitration-skill/intake-manifest-builder"},
        "version": {"const": "0.3.0"},
        "build_identity_status": {"const": "UNATTESTED"},
        "runtime_source_sha256": {
          "oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
        },
        "dependency_contract_sha256": {
          "oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
        },
        "dependency_contract_kind": {
          "enum": ["HASH_LOCK", "DIRECT_REQUIREMENTS"]
        },
        "python_version": {"type": "string", "minLength": 1},
        "platform": {"type": "string", "minLength": 1}
      }
    },
    "provenance_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_observations",
        "user_declarations",
        "generator_authenticity"
      ],
      "properties": {
        "system_observations": {"const": "SYSTEM_OBSERVED_UNATTESTED"},
        "user_declarations": {"const": "NOT_PROVIDED"},
        "generator_authenticity": {"const": "NOT_VERIFIED"}
      }
    },
    "scan_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at", "completed_at", "clock_status", "tree_walks_completed"],
      "properties": {
        "started_at": {"type": "string", "format": "date-time"},
        "completed_at": {"type": "string", "format": "date-time"},
        "clock_status": {"const": "SYSTEM_CLOCK_UNATTESTED"},
        "tree_walks_completed": {"const": 2}
      }
    },
    "output_security": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "permissions_enforcement",
        "absolute_paths_emitted",
        "relative_paths_may_contain_sensitive_data"
      ],
      "properties": {
        "permissions_enforcement": {
          "enum": [
            "POSIX_MODE_0600",
            "WINDOWS_DIRECTORY_ACL_INHERITED_NOT_VERIFIED"
          ]
        },
        "absolute_paths_emitted": {"const": false},
        "relative_paths_may_contain_sensitive_data": {"const": true}
      }
    },
    "scan_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_depth",
        "max_file_bytes",
        "max_files",
        "max_total_bytes",
        "timeout_seconds"
      ],
      "properties": {
        "max_depth": {"type": "integer", "minimum": 0},
        "max_file_bytes": {"type": "integer", "minimum": 1},
        "max_files": {"type": "integer", "minimum": 1},
        "max_total_bytes": {"type": "integer", "minimum": 1},
        "timeout_seconds": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_count", "total_bytes"],
      "properties": {
        "file_count": {"type": "integer", "minimum": 0},
        "total_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "relationships": {
      "type": "array",
      "items": {"$ref": "#/$defs/relationship"}
    },
    "files": {
      "type": "array",
      "items": {"$ref": "#/$defs/raw_file"}
    },
    "manifest_payload_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "raw_file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_id",
        "relative_path",
        "path_sha256",
        "extension",
        "detected_media_type",
        "media_type_detection",
        "extension_media_type_mismatch",
        "size_bytes",
        "sha256",
        "modified_at_ns",
        "filesystem_identity_sha256",
        "integrity_status",
        "observation_status",
        "user_provenance_status"
      ],
      "properties": {
        "raw_id": {"type": "string", "pattern": "^RAW-[0-9a-f]{64}$"},
        "relative_path": {"type": "string", "minLength": 1},
        "path_sha256": {"$ref": "#/$defs/sha256"},
        "extension": {"type": "string"},
        "detected_media_type": {"type": "string", "minLength": 1},
        "media_type_detection": {"const": "MAGIC_PREFIX_V1"},
        "extension_media_type_mismatch": {"type": "boolean"},
        "size_bytes": {"type": "integer", "minimum": 0},
        "sha256": {"$ref": "#/$defs/sha256"},
        "modified_at_ns": {"type": "string", "pattern": "^[0-9]+$"},
        "filesystem_identity_sha256": {"$ref": "#/$defs/sha256"},
        "integrity_status": {"const": "INGESTION_BYTES_OBSERVED"},
        "observation_status": {"const": "SYSTEM_OBSERVED_UNATTESTED"},
        "user_provenance_status": {"const": "NOT_PROVIDED"}
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relationship_type",
        "identity_sha256",
        "raw_ids",
        "observation_status"
      ],
      "properties": {
        "relationship_type": {"enum": ["DUPLICATE_CONTENT", "HARDLINK_CANDIDATE"]},
        "identity_sha256": {"$ref": "#/$defs/sha256"},
        "raw_ids": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^RAW-[0-9a-f]{64}$"}
        },
        "observation_status": {"const": "SYSTEM_OBSERVED_UNATTESTED"}
      }
    }
  }
}
