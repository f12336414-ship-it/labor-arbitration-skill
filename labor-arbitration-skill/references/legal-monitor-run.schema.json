{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/f12336414-ship-it/labor-arbitration-skill/legal-monitor-run.schema.json",
  "title": "Legal update monitor run and alert record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "monitor_id", "definition_binding", "evaluated_at", "clock_status", "previous_binding", "freshness_checks", "source_states", "alerts", "overall_status", "required_output_state", "legal_review_required", "limitations", "run_snapshot_sha256"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^LMRUN-[0-9A-F]{24}$"},
    "monitor_id": {"type": "string", "pattern": "^LEGALMON-[A-Z0-9][A-Z0-9_-]{0,54}$"},
    "definition_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["definition_id", "definition_snapshot_sha256"],
      "properties": {
        "definition_id": {"type": "string", "pattern": "^LMDEF-[0-9A-F]{24}$"},
        "definition_snapshot_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "evaluated_at": {"type": "string", "format": "date-time"},
    "clock_status": {"const": "SYSTEM_CLOCK_UNATTESTED"},
    "previous_binding": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object", "additionalProperties": false,
          "required": ["run_id", "run_snapshot_sha256", "evaluated_at", "definition_binding"],
          "properties": {
            "run_id": {"type": "string", "pattern": "^LMRUN-[0-9A-F]{24}$"},
            "run_snapshot_sha256": {"$ref": "#/$defs/sha256"},
            "evaluated_at": {"type": "string", "format": "date-time"},
            "definition_binding": {
              "type": "object", "additionalProperties": false,
              "required": ["definition_id", "definition_snapshot_sha256"],
              "properties": {
                "definition_id": {"type": "string", "pattern": "^LMDEF-[0-9A-F]{24}$"},
                "definition_snapshot_sha256": {"$ref": "#/$defs/sha256"}
              }
            }
          }
        }
      ]
    },
    "freshness_checks": {
      "type": "array", "maxItems": 100,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["source_monitor_id", "check"],
        "properties": {
          "source_monitor_id": {"type": "string", "pattern": "^LSOURCE-[A-Z0-9][A-Z0-9_-]{0,54}$"},
          "check": {"type": "object"}
        }
      }
    },
    "source_states": {
      "type": "array", "minItems": 1, "maxItems": 100,
      "items": {"$ref": "#/$defs/source_state"}
    },
    "alerts": {"type": "array", "maxItems": 500, "items": {"$ref": "#/$defs/alert"}},
    "overall_status": {"enum": ["HEALTHY_TECHNICALLY_UNCHANGED", "WARNING_DRAFT_ONLY", "CRITICAL_DRAFT_ONLY"]},
    "required_output_state": {"enum": ["NO_PROMOTION_GRANTED", "DRAFT"]},
    "legal_review_required": {"const": true},
    "limitations": {
      "const": [
        "UNCHANGED_BYTES_DO_NOT_PROVE_LEGAL_CURRENTNESS",
        "MONITOR_CLOCK_AND_SCHEDULER_ARE_NOT_ATTESTED",
        "PUBLISHER_AUTHORSHIP_LEGAL_EFFECT_AND_APPLICABILITY_NOT_VERIFIED",
        "NO_AUTOMATIC_BASELINE_PROMOTION_AFTER_CHANGE",
        "NO_SUBMISSION_READINESS"
      ]
    },
    "run_snapshot_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_state": {
      "type": "object", "additionalProperties": false,
      "required": ["source_monitor_id", "document_id", "check_execution_status", "technical_freshness_status", "latest_check_id", "latest_check_snapshot_sha256", "last_checked_at", "next_due_at", "recent_outcomes", "error_budget", "required_output_state"],
      "properties": {
        "source_monitor_id": {"type": "string", "pattern": "^LSOURCE-[A-Z0-9][A-Z0-9_-]{0,54}$"},
        "document_id": {"type": "string", "minLength": 3, "maxLength": 64, "pattern": "^[A-Z][A-Z0-9_-]+$"},
        "check_execution_status": {"enum": ["CHECKED", "MISSED_DUE_CHECK", "CARRIED_FORWARD_NOT_DUE"]},
        "technical_freshness_status": {"enum": ["UNCHANGED_RESPONSE_BODY_CANDIDATE", "CHANGE_DETECTED_REVIEW_REQUIRED", "UNAVAILABLE_DRAFT_ONLY", "STALE_DRAFT_ONLY", "NOT_CHECKED_MISSED_DRAFT_ONLY"]},
        "latest_check_id": {"type": ["string", "null"], "pattern": "^FRESH-[A-Z0-9][A-Z0-9_-]{0,55}$"},
        "latest_check_snapshot_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "last_checked_at": {"type": ["string", "null"], "format": "date-time"},
        "next_due_at": {"type": "string", "format": "date-time"},
        "recent_outcomes": {"type": "array", "minItems": 1, "maxItems": 100, "items": {"enum": ["SUCCESS", "UNAVAILABLE", "MISSED"]}},
        "error_budget": {
          "type": "object", "additionalProperties": false,
          "required": ["window_runs", "max_failures", "observed_failures", "status"],
          "properties": {
            "window_runs": {"type": "integer", "minimum": 1, "maximum": 100},
            "max_failures": {"type": "integer", "minimum": 0, "maximum": 99},
            "observed_failures": {"type": "integer", "minimum": 0, "maximum": 100},
            "status": {"enum": ["WITHIN_BUDGET", "EXHAUSTED"]}
          }
        },
        "required_output_state": {"enum": ["NO_PROMOTION_GRANTED", "DRAFT"]}
      }
    },
    "alert": {
      "type": "object", "additionalProperties": false,
      "required": ["alert_id", "source_monitor_id", "code", "severity", "status", "check_id", "check_snapshot_sha256"],
      "properties": {
        "alert_id": {"type": "string", "pattern": "^LMALERT-[0-9A-F]{24}$"},
        "source_monitor_id": {"type": "string", "pattern": "^LSOURCE-[A-Z0-9][A-Z0-9_-]{0,54}$"},
        "code": {"enum": ["LEGAL_SOURCE_CHANGE_DETECTED", "LEGAL_SOURCE_CHECK_UNAVAILABLE", "LEGAL_SOURCE_CHECK_STALE", "LEGAL_SOURCE_CHECK_MISSED", "LEGAL_SOURCE_ERROR_BUDGET_EXHAUSTED"]},
        "severity": {"enum": ["WARNING", "HIGH", "CRITICAL"]},
        "status": {"const": "OPEN_REQUIRES_HUMAN_REVIEW"},
        "check_id": {"type": ["string", "null"], "pattern": "^FRESH-[A-Z0-9][A-Z0-9_-]{0,55}$"},
        "check_snapshot_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
